# BitAiir Core configuration file.
#
# Copy this file to `bitaiir.toml` (or pass --config <path>) and
# uncomment the settings you want to customize.  CLI flags always
# take priority over values set here.
#
# The daemon auto-creates a default `bitaiir.toml` on first run if
# none exists.

[network]
# Run on the testnet network instead of mainnet.  Testnet uses
# different magic bytes, a different genesis block, faster coinbase
# maturity (10 blocks vs 100), and separate default ports and data
# dir — so mainnet and testnet nodes cannot accidentally peer with
# each other, and you can run both side by side on the same machine.
# Equivalent to the --testnet CLI flag.
# testnet = false

# JSON-RPC server bind address.
# Default: mainnet = 127.0.0.1:8443, testnet = 127.0.0.1:18443.
# rpc_addr = "127.0.0.1:8443"

# P2P listener bind address.
# Default: mainnet = 127.0.0.1:8444, testnet = 127.0.0.1:18444.
# p2p_addr = "127.0.0.1:8444"

# Peers to connect to on startup.  Same as --connect on the CLI.
# connect = ["127.0.0.1:8544", "1.2.3.4:8444"]

# Per-peer message rate limit (token bucket).  A peer sustaining
# more than `rate_limit_msgs_per_sec` messages per second, or
# bursting past `rate_limit_burst` in aggregate, is disconnected
# and banned for `rate_limit_ban_secs` seconds.  The ban is
# persisted in the known_peers table for outbound-history peers;
# inbound-only peers are tracked in memory until restart.
# Defaults: 100 msgs/s, burst 200, ban 600s.
# rate_limit_msgs_per_sec = 100
# rate_limit_burst        = 200
# rate_limit_ban_secs     = 600

[mining]
# Start mining automatically on daemon startup (same as --mine).
# enabled = false

# Number of parallel mining threads.  0 = auto (min(4, cores/2)).
# Each thread uses ~64 MiB of RAM for Argon2id.
# threads = 0

[storage]
# Directory for chain database, wallet keys, and peer data.
# Default: mainnet = "bitaiir_data", testnet = "bitaiir_testnet_data".
# data_dir = "bitaiir_data"

[mempool]
# Maximum total serialized bytes held in the mempool before
# eviction kicks in.  When a new transaction arrives and the pool
# is at capacity, the lowest-priority transaction (lowest
# pow_priority, then newest arrival on ties) is evicted to make
# room.  If the incoming transaction itself would be the lowest-
# priority, it is rejected instead.  Default: 50 MB.
# max_bytes = 50000000

[rpc]
# Authentication for the JSON-RPC server.
#
# By default the daemon writes a random cookie to
# `<data_dir>/.cookie` on startup.  `bitaiir-cli` on the same
# machine reads that cookie automatically — no config needed for
# local use.
#
# Set explicit credentials below to use config-based auth instead.
# When both `user` and `password` are set, the cookie file is NOT
# generated; clients must pass `--rpc-user` / `--rpc-password`
# explicitly.  Useful when exposing RPC over a LAN or reverse proxy.
#
# user = "bitaiir"
# password = "change-me"
#
# IP allowlist.  When set, only connections from these IPs or CIDR
# ranges reach the RPC server.  All other IPs are dropped at the
# TCP level before authentication is even attempted.
# Leave unset (or empty) to accept connections from any IP (auth
# is still enforced regardless).
#
# allow_ip = ["127.0.0.1", "192.168.1.0/24"]

# Serve RPC over HTTPS instead of plain HTTP.  When true and no
# explicit cert/key paths are provided, the daemon generates a
# self-signed ECDSA P-256 pair valid for 10 years (CN = BitAiir
# RPC, SANs = localhost + 127.0.0.1 + ::1) in
# `<data_dir>/rpc.cert` + `<data_dir>/rpc.key` on first startup and
# reuses it on subsequent runs.  `bitaiir-cli` auto-trusts that
# file, so local use is zero-config.
#
# For LAN or public deployment, point the two paths below at a
# cert signed by a real CA (Let's Encrypt, internal PKI, etc.) —
# the daemon loads them as-is and does not generate anything.
#
# tls = false
# tls_cert_path = "/etc/letsencrypt/live/node.example.com/fullchain.pem"
# tls_key_path  = "/etc/letsencrypt/live/node.example.com/privkey.pem"
